# AdLoop configuration
# Copy this file to ~/.adloop/config.yaml and fill in your values.
#
# Most users only need to set: developer_token, customer_id, login_customer_id.
# The setup wizard (adloop init) handles everything automatically.
#
# See README.md for detailed setup instructions.

google:
  # Leave credentials_path empty to use AdLoop's built-in OAuth credentials.
  # Only set this if you're using your own Google Cloud project or a service account.
  # credentials_path: "~/.adloop/credentials.json"

  # OAuth token is stored here automatically after first login.
  # You shouldn't need to touch this.
  token_path: "~/.adloop/token.json"

ga4:
  # Your GA4 property ID (numeric).
  # Find it in GA4 → Admin → Property Settings.
  # The setup wizard auto-discovers this after OAuth.
  property_id: ""

ads:
  # Google Ads API developer token.
  # Find it in your MCC account → Tools & Settings → API Center.
  # Explorer access (automatic) gives 2,880 operations/day.
  # Apply for Basic access for 15,000 operations/day.
  developer_token: ""

  # Default Google Ads customer ID (e.g. "123-456-7890").
  # This is the account you want to manage, not the MCC.
  # The setup wizard auto-discovers this after OAuth.
  customer_id: ""

  # Your MCC (Manager) account ID (e.g. "123-456-7890").
  # Required for API access — even if you only manage one account.
  login_customer_id: ""

gsc:
  # Your Google Search Console site URL.
  # Use the exact URL shown in the GSC property selector, e.g.:
  #   "https://example.com/"         (URL-prefix property)
  #   "sc-domain:example.com"        (Domain property)
  # Leave empty to pass site_url as a parameter in each tool call instead.
  site_url: ""

safety:
  # Maximum daily budget allowed per campaign (in your account's currency).
  # AdLoop will reject any campaign creation or budget change above this.
  max_daily_budget: 50.00

  # Maximum percentage a bid can increase in a single operation.
  max_bid_increase_pct: 100

  # Force all write operations to dry-run mode.
  # Set to false only when you're ready to make real changes.
  require_dry_run: true

  # Path to the audit log file. All operations are logged here.
  log_file: "~/.adloop/audit.log"

  # List of operations to block entirely (e.g. ["remove_entity"]).
  blocked_operations: []
